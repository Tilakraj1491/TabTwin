# Example environment variables for the TabTwin signaling server and AI agent.
ANTHROPIC_API_KEY=your_claude_api_key_here
PORT=3001
CLIENT_URL=http://localhost:5173

# Redis connection URL for persistent, multi-instance session storage.
# If omitted, the server falls back to an in-memory store that is suitable
# for local development but loses all sessions on restart.
# Quick start: docker run -d -p 6379:6379 redis:7-alpine
# REDIS_URL=redis://localhost:6379
